{
  "name": "rebuiltstefenmarg",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "cross-env environment=Dev npm-run-all --parallel serve_dev:*",
    "prod": "cross-env environment=Prod npm-run-all build_prod:*",
    
    "build_prod:eleventy": "eleventy",
    "serve_dev:eleventy": "eleventy --serve",

    "build_prod:scss": "npx sass ./Source/public/scss/global.scss ./Source/public/css/global.css --no-source-map --verbose",
    "serve_dev:scss": "npx sass ./Source/public/scss/global.scss ./Source/public/css/global.css --no-source-map --verbose --watch",

    "build_prod:webpack": "webpack --config webpack.config.js",
    "serve_dev:webpack": "webpack --config webpack.config.js --watch"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "description": "",
  "dependencies": {
    "@11ty/eleventy": "^3.0.0",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.0",
    "@babel/core": "^7.26.7",
    "@babel/preset-env": "^7.26.7",
    "babel-loader": "^9.2.1",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.7",
    "npm-run-all": "^4.1.5",
    "sass": "^1.86.2",
    "sass-migrator": "^2.3.1",
    "webpack": "^5.97.1",
    "webpack-cli": "^6.0.1"
  }
}
